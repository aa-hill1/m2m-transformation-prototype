record PID {
	error : real
	integral : real
	output : real
	P : real
	I : real
	D : real
}

function computePID ( pid : PID , newError : real , dtime : real ) : PID {
	precondition dtime > 0
	postcondition
		let derror == newError-pid.error @
		let integral == pid.integral + dtime*pid.error + (dtime*derror)/2 @
			(result.error == newError /\
			result.integral == integral /\
			result.output == pid.P*newError + pid.I*integral + pid.D*derror/dtime /\
			result.P == pid.P /\ result.I == pid.I /\ result.D == pid.D)
}

function initialisePID ( P : real , I : real , D : real ) : PID {
	postcondition result.P == P /\ result.I == I /\ result.D == D /\
		result.error == 0 /\ result.integral == 0 /\ result.output == 0
}
interface MotorsI {
	setLeftMotorSpeed ( speed : real )
	setRightMotorSpeed ( speed : real )
}

interface HallSensorsI {
	event leftMotorVelocity : real
	event rightMotorVelocity : real
}

interface IMUI {
	event angle : real
	event gyroX : real
	event gyroY : real
	event gyroZ : real
}

interface InterruptsI {
	enableInterrupts ( )
	disableInterrupts ( )
}

robotic platform SegwayRP {
	uses HallSensorsI uses IMUI provides MotorsI provides InterruptsI }
stm BalanceSTM {
	requires MotorsI 
	
	
	const maxAngle : real
	var anglePID : PID , speedPID : PID , rotationPID : PID
	const loopTime : nat
	uses HallSensorsI uses IMUI requires InterruptsI var currAngle : real , currGyroX : real , currGyroY : real , currGyroZ : real , currLeftVel : real , currRightVel : real
	const startupDelay : nat
	const angleP : real , angleI : real , angleD : real , speedP : real , speedI : real , speedD : real , rotationP : real , rotationI : real , rotationD : real
	var speedCount : nat , rotationCount : nat
	initial i0

	state CalculateAngle {
		entry enableInterrupts ( ) ; angle ? currAngle <{ 0 } ; anglePID = computePID ( anglePID , currAngle , loopTime ) ; wait ( [ 0 , angleBudget ] )
	}

	state CalculateSpeed {
		entry leftMotorVelocity ? currLeftVel <{ 0 } ; rightMotorVelocity ? currRightVel <{ 0 } ; speedPID = computePID ( speedPID , currLeftVel + currRightVel , loopTime * speedUpdate ) ; speedCount = 0 ; wait ( [ 0 , speedBudget ] )
	}
	state CalculateRotation {
		entry gyroZ ? currGyroZ <{ 0 } ; rotationPID = computePID ( rotationPID , rotationPID . error + currGyroZ , loopTime * rotationUpdate ) ; rotationCount = 0 ; wait ( [ 0 , rotationBudget ] )
	}
	state SetMotors {
		entry setLeftMotorSpeed ( anglePID . output + speedPID . output - rotationPID . output ) ; setRightMotorSpeed ( anglePID . output + speedPID . output + rotationPID . output ) ; wait ( [ 0 , motorBudget ] )
	}
	junction j0
	junction j1
	junction j2
	state StopMotors {
		entry setLeftMotorSpeed ( 0 ) ; setRightMotorSpeed ( 0 ) ; wait ( [ 0 , motorBudget ] )
	}
	state WaitForNextIteration {
	}
	state Initialisation {
		entry speedCount = 0; rotationCount = 0;
			anglePID = initialisePID(angleP, angleI, angleD);
			speedPID = initialisePID(speedP, speedI, speedD);
			rotationPID = initialisePID(rotationP, rotationI, rotationD);
			wait(startupDelay) ; # loopTimer
	}
	junction j3
	transition t1 {
		from j0
		to CalculateSpeed
		condition speedCount >= speedUpdate
	}
	transition t2 {
		from CalculateSpeed
		to j1
	}
	transition t3 {
		from CalculateAngle
		to j0
		action speedCount = speedCount + 1
	}
	transition t4 {
		from j0
		to j1
		condition speedCount < speedUpdate
	}
	transition t8 {
		from CalculateRotation
		to j2
	}
	transition t9 {
		from j2
		to SetMotors
		condition currAngle <= maxAngle /\ currAngle >= - maxAngle
	}
	transition t10 {
		from j2
		to StopMotors
		condition currAngle > maxAngle \/ currAngle < - maxAngle
	}
	transition t12 {
		from WaitForNextIteration
		to CalculateAngle
		# loopTimer
		condition since ( loopTimer ) >= loopTime
		action disableInterrupts ( )
	}
	transition t7 {
		from StopMotors
		to WaitForNextIteration
	}
	transition t11 {
		from SetMotors
		to WaitForNextIteration
	}
	clock loopTimer
	transition t0 {
		from i0
		to Initialisation
	}
	transition t13 {
		from Initialisation
		to WaitForNextIteration
	}
	const speedUpdate : nat , rotationUpdate : nat
	transition t5 {
		from j1
		to j3
		action rotationCount = rotationCount + 1
	}
	transition t6 {
		from j3
		to CalculateRotation
		condition rotationCount >= rotationUpdate
	}
	transition t14 {
		from j3
		to j2
		condition rotationCount < rotationUpdate
	}
	const angleBudget : nat , speedBudget : nat , rotationBudget : nat , motorBudget : nat
}
module Segway {
	controller SegwayController {
		uses HallSensorsI uses IMUI requires MotorsI requires InterruptsI sref stm_ref0 = BalanceSTM
		connection SegwayController on leftMotorVelocity to stm_ref0 on leftMotorVelocity
		connection SegwayController on rightMotorVelocity to stm_ref0 on rightMotorVelocity
		connection SegwayController on angle to stm_ref0 on angle
		connection SegwayController on gyroX to stm_ref0 on gyroX
		connection SegwayController on gyroY to stm_ref0 on gyroY
		connection SegwayController on gyroZ to stm_ref0 on gyroZ
	}
	rref rp_ref0 = SegwayRP
	connection rp_ref0 on rightMotorVelocity to SegwayController on leftMotorVelocity ( _async )
	connection rp_ref0 on leftMotorVelocity to SegwayController on rightMotorVelocity ( _async )
	connection rp_ref0 on angle to SegwayController on angle ( _async )
	connection rp_ref0 on gyroX to SegwayController on gyroX ( _async )
	connection rp_ref0 on gyroY to SegwayController on gyroY ( _async )
	connection rp_ref0 on gyroZ to SegwayController on gyroZ ( _async )
}